# Network Triage Tool - Environment Variables Example
# Copy this file to `.env` and adjust values as needed

# Application Settings
NETWORK_TRIAGE_LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
NETWORK_TRIAGE_LOG_FILE=network_triage.log  # Log file path (optional)
NETWORK_TRIAGE_CACHE_DIR=~/.cache/network-triage  # Cache directory

# Network Operation Settings
NETWORK_TRIAGE_DNS_TIMEOUT=5  # DNS query timeout in seconds
NETWORK_TRIAGE_PORT_SCAN_TIMEOUT=2  # Port scan timeout per port
NETWORK_TRIAGE_MAX_CONCURRENT_SCANS=10  # Maximum concurrent port scans
NETWORK_TRIAGE_PING_COUNT=4  # Default ping count
NETWORK_TRIAGE_PING_TIMEOUT=2  # Ping timeout in seconds

# External Service Settings
NETWORK_TRIAGE_SPEEDTEST_SERVER=auto  # Speedtest server ID or 'auto'
NETWORK_TRIAGE_IP_API_URL=https://api.ipify.org?format=json  # Public IP API
NETWORK_TRIAGE_DNS_SERVERS=8.8.8.8,1.1.1.1  # Default DNS servers (comma-separated)

# UI Settings
NETWORK_TRIAGE_THEME=dark  # dark, light, auto
NETWORK_TRIAGE_REFRESH_INTERVAL=60  # Dashboard refresh interval in seconds
NETWORK_TRIAGE_MAX_HISTORY_ENTRIES=100  # Maximum history entries to keep

# Development Settings
NETWORK_TRIAGE_DEBUG=false  # Enable debug mode
NETWORK_TRIAGE_MOCK_NETWORK=false  # Mock network operations for testing
NETWORK_TRIAGE_DISABLE_ANIMATIONS=false  # Disable UI animations for testing

# Security Settings (Optional)
# NETWORK_TRIAGE_API_KEY=your_api_key_here  # For external API services
# NETWORK_TRIAGE_PROXY=http://proxy.example.com:8080  # Proxy server URL

# Platform-Specific Settings
# macOS specific
NETWORK_TRIAGE_MACOS_NETWORK_SETUP=/usr/sbin/networksetup

# Linux specific
NETWORK_TRIAGE_LINUX_IP_COMMAND=/usr/sbin/ip
NETWORK_TRIAGE_LINUX_ETHTOOL=/usr/sbin/ethtool

# Windows specific
NETWORK_TRIAGE_WINDOWS_NETSH=C:\\Windows\\System32\\netsh.exe

# Notes:
# 1. Never commit actual secrets to version control
# 2. Use .gitignore to exclude .env file
# 3. Load with: python-dotenv or pydantic-settings
# 4. Environment variables override config file settings
